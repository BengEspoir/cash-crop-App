## Server
NODE_ENV=development
PORT=5000
API_VERSION=v1
BASE_URL=http://localhost:5000

## Supabase
SUPABASE_URL=https://jftggxxzqtmmqktvnlwc.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
# Optional in development because the server can fall back for local boot.
# For real writes and production behavior, set the actual service-role key.
SUPABASE_SERVICE_ROLE_KEY=
# Private bucket for National ID and selfie uploads. Create it in Supabase Storage
# with public access disabled.
SUPABASE_VERIFICATION_BUCKET=farmer-verifications
SUPABASE_ASSETS_BUCKET=agriculnet-assets

## JWT
JWT_ACCESS_SECRET=replace-with-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-another-64-char-random-hex-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

## Bcrypt
BCRYPT_SALT_ROUNDS=12

## Email
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Gmail SMTP requires a Gmail App Password, not your normal Google password.
SMTP_USER=
SMTP_PASS=
# Prefer using the same mailbox as SMTP_USER while using Gmail SMTP.
EMAIL_FROM=AgriculNet <no-reply@agriculnet.cm>

## SendGrid (optional - for production email)
SENDGRID_API_KEY=

## Mailgun (optional - for production email)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

## SMS
# Sandbox mode: AT_SANDBOX=true and AT_USERNAME=sandbox with your sandbox API key.
# Live mode: AT_SANDBOX=false and AT_USERNAME=your live Africa's Talking app username.
# Leave AT_SENDER_ID blank for school/dev projects to use Africa's Talking's default sender.
# Only set AT_SENDER_ID after it has been approved on your Africa's Talking account.
SMS_PRIMARY_PROVIDER=africastalking
AT_API_KEY=replace-with-your-africas-talking-api-key
AT_USERNAME=replace-with-your-africas-talking-username
AT_SENDER_ID=
AT_SANDBOX=true
SMS_TEST_TO=+2376XXXXXXXX

## Twilio (optional - for international SMS)
TWILIO_ACCOUNT_SID=replace-with-your-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-your-twilio-phone-number

## Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## OTP
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3

## Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

## Client URLs
CLIENT_URL=http://localhost:3000
EMAIL_VERIFY_URL=http://localhost:3000/verify-email
PASSWORD_RESET_URL=http://localhost:3000/reset-password

## Admin
ADMIN_ROUTE_SECRET=replace-with-strong-admin-route-secret

## Development helpers
ALLOW_DEV_DELIVERY_FALLBACK=true
EXPOSE_DEV_AUTH_HINTS=true
